# Copy this file to ".env" and fill in your values from Supabase → Project Settings.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Project Settings → API Keys → "Publishable key" (starts with sb_publishable_...).
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Older projects only: if your project still uses the legacy "anon" key, you can set that instead:
# VITE_SUPABASE_ANON_KEY=your-legacy-anon-key
